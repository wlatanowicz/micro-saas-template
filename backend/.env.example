DATABASE_URL=postgresql://user:password@host:5432/dbname
# Required when DATABASE_URL is set: HS256 signing key for access tokens
JWT_SECRET=change-me-in-production

# Auth methods (true/false). Password is enabled by default.
AUTH_PASSWORD_ENABLED=true
AUTH_GOOGLE_ENABLED=false
AUTH_FACEBOOK_ENABLED=false

# OAuth credentials (required when the matching AUTH_*_ENABLED flag is true)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_FACEBOOK_APP_ID=
AUTH_FACEBOOK_APP_SECRET=

# SPA URL for post-OAuth redirect (token delivered in URL hash)
AUTH_FRONTEND_URL=http://localhost:5173

# Register these redirect URIs in Google Cloud Console / Meta Developer:
#   http://localhost:8000/api/auth/google/callback
#   http://localhost:8000/api/auth/facebook/callback
#   https://<api-domain>/api/auth/google/callback
#   https://<api-domain>/api/auth/facebook/callback

# Email notifications (verification codes). local = write .eml files; ses = Amazon SES.
NOTIFICATIONS_TRANSPORT=local
NOTIFICATIONS_FROM_EMAIL=noreply@example.com
# NOTIFICATIONS_EML_DIR=var/emails

# Scheduled tasks. sync = run in-process; sqs = Amazon SQS (required on Lambda).
SCHEDULER_TRANSPORT=sync
# SCHEDULER_QUEUE_MESSAGES_URL=https://sqs.eu-central-1.amazonaws.com/123456789012/queue-name
